# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# Mapbox (geocoding, address autocomplete, maps)
# =============================================================================
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# =============================================================================
# Mollie (payments)
# =============================================================================
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# Sumsub (KYC identity verification)
# =============================================================================
SUMSUB_APP_TOKEN=your-sumsub-app-token
SUMSUB_SECRET_KEY=your-sumsub-secret-key

# =============================================================================
# OneSignal (push notifications)
# =============================================================================
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# =============================================================================
# SMSFactor (SMS notifications)
# =============================================================================
SMSFACTOR_API_KEY=your-smsfactor-api-key

# =============================================================================
# INSEE / Sirene (SIRET business verification)
# =============================================================================
INSEE_API_TOKEN=your-insee-api-token

# =============================================================================
# Resend (transactional emails)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@demenagement24.fr

# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_URL=http://localhost:3000
