# =============================================================================
# Supabase
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# Mapbox (geocoding, address autocomplete, maps)
# =============================================================================
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# =============================================================================
# Mollie (payments)
# =============================================================================
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# didit.me (KYC identity verification)
# =============================================================================
DIDIT_API_KEY=your-didit-api-key
DIDIT_WEBHOOK_SECRET=your-didit-webhook-secret
DIDIT_WORKFLOW_ID=your-didit-workflow-id

# =============================================================================
# OneSignal (push notifications)
# =============================================================================
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# =============================================================================
# SMSFactor (SMS notifications)
# =============================================================================
SMSFACTOR_API_KEY=your-smsfactor-api-key
# SMS sender ID shown to recipients (11 alphanumeric chars max on most carriers)
SMS_SENDER=

# =============================================================================
# INSEE / Sirene (SIRET business verification)
# =============================================================================
INSEE_API_TOKEN=your-insee-api-token

# =============================================================================
# Resend (transactional emails)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@example.com

# =============================================================================
# Application / Brand identity
# =============================================================================
NEXT_PUBLIC_URL=http://localhost:3000

# Brand identity — consumed by src/lib/brand.ts. Leave unset in dev until you
# pick a domain; the app will show empty strings as fallback.
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
ADMIN_EMAIL=

# =============================================================================
# Sentry (error monitoring)
# =============================================================================
# Leave unset locally to disable Sentry entirely (init() bails without a DSN).
# Set NEXT_PUBLIC_SENTRY_DSN in Vercel to enable client + server capture.
NEXT_PUBLIC_SENTRY_DSN=
# Optional, for source-map upload during `next build`. Without these the build
# works but stack traces in Sentry are minified.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# =============================================================================
# Vercel API (for /admin/system health dashboard — optional)
# =============================================================================
# Create a personal token at https://vercel.com/account/tokens (read scope is enough).
# VERCEL_PROJECT_ID is shown on the Project Settings page. VERCEL_TEAM_ID is
# required only if the project belongs to a team (not a personal account).
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# =============================================================================
# Lead verification
# =============================================================================
# When "false", POST /api/quotes distributes leads to movers immediately
# (pre-feature behavior) without requiring email/phone OTP verification.
# Any other value (or unset) → leads are held until the client verifies at
# least one contact channel on /verifier-demande/[id].
LEAD_VERIFICATION_ENABLED=true
